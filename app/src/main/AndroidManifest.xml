<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/famcart_logo"
        android:label="FamCart"
        android:roundIcon="@drawable/famcart_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.FamCart">

        <activity android:name="com.example.testing.SignupActivity"
            tools:ignore="MissingClass" />
        <activity android:name="com.example.testing.LoginActivity" />
        <activity
            android:name="com.example.testing.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.example.testing.MainActivity"
            android:exported="false" />
        <activity
            android:name="com.example.testing.SearchActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible|adjustResize" />
        <activity
            android:name="com.example.testing.ProductDetailActivity"
            android:exported="false" />
        <activity
            android:name="com.example.testing.CartActivity"
            android:exported="false" />
        <activity
            android:name="com.example.testing.CheckoutActivity"
            android:exported="false" />
        <activity
            android:name="com.example.testing.OrdersActivity"
            android:exported="false" />
    </application>

</manifest>