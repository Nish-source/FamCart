<?xml version="1.0" encoding="utf-8"?>
<!-- Cart item row — matches Figma Cart screen design -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <!-- Product Image with light green background -->
        <FrameLayout
            android:id="@+id/frame_image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_image_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_product_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Product image"
                android:padding="4dp"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <!-- Product Name -->
        <TextView
            android:id="@+id/tv_product_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="#101828"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@id/btn_delete"
            app:layout_constraintStart_toEndOf="@id/frame_image"
            app:layout_constraintTop_toTopOf="@id/frame_image" />

        <!-- Product Quantity/Weight subtitle -->
        <TextView
            android:id="@+id/tv_product_quantity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:textColor="#99A1AF"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/btn_delete"
            app:layout_constraintStart_toEndOf="@id/frame_image"
            app:layout_constraintTop_toBottomOf="@id/tv_product_name" />

        <!-- Red Delete Button -->
        <FrameLayout
            android:id="@+id/btn_delete"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_delete_button"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_gravity="center"
                android:contentDescription="Remove item"
                android:src="@drawable/ic_delete"
                app:tint="#EF4444" />
        </FrameLayout>

        <!-- Bottom row: Price + Qty stepper -->
        <TextView
            android:id="@+id/tv_item_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-black"
            android:textColor="#101828"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/frame_image"
            app:layout_constraintStart_toEndOf="@id/frame_image" />

        <!-- Pill-shaped Qty Stepper -->
        <LinearLayout
            android:id="@+id/layout_qty_stepper"
            android:layout_width="96dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_qty_stepper_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            app:layout_constraintBottom_toBottomOf="@id/frame_image"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/btn_qty_minus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Decrease"
                android:focusable="true"
                android:padding="7dp"
                android:src="@drawable/ic_minus"
                app:tint="#6A7282" />

            <TextView
                android:id="@+id/tv_qty_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:textColor="#101828"
                android:textSize="13sp" />

            <ImageView
                android:id="@+id/btn_qty_plus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Increase"
                android:focusable="true"
                android:padding="7dp"
                android:src="@drawable/ic_plus"
                app:tint="#22C55E" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
