<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/admin_order_card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_admin_order_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:elevation="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Header: Order ID + Status Badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_admin_order_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.025"
            android:textColor="#101828"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_admin_order_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_placed"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Customer Name -->
    <TextView
        android:id="@+id/tv_admin_user_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#364153"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Address + Phone row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tv_admin_user_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:textColor="#6A7282"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_admin_user_phone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif"
                android:textColor="#99A1AF"
                android:textSize="11sp"
                android:maxLines="1"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_admin_order_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="#99A1AF"
                android:textSize="11sp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="12dp"
        android:background="#F3F4F6" />

    <!-- Order Items Container -->
    <LinearLayout
        android:id="@+id/layout_admin_order_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="12dp"
        android:background="#F3F4F6" />

    <!-- Total + Payment Method -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Total Amount"
                android:textColor="#6A7282"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_admin_payment_method"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="#99A1AF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_admin_order_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textColor="#101828"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/layout_admin_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_reject_order"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="Reject"
            android:textColor="#EF4444"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_reject_button"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_accept_order"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1.5"
            android:text="Accept Order"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:background="@drawable/bg_accept_button"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Mark Complete button (shown for Accepted orders) -->
    <TextView
        android:id="@+id/btn_complete_order"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="14dp"
        android:text="Mark as Completed ✓"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        android:background="@drawable/bg_admin_button"
        android:gravity="center"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
