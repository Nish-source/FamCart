    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <ImageView
            android:id="@+id/btn_admin_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="Back"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Panel"
                android:textSize="18sp"
                android:textColor="#101828"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.025" />

            <TextView
                android:id="@+id/tv_order_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading orders..."
                android:textSize="12sp"
                android:textColor="#99A1AF"
                android:fontFamily="sans-serif" />

        </LinearLayout>

        <!-- Logout -->
        <TextView
            android:id="@+id/btn_admin_logout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Logout"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Filter Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="All Orders"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_admin_button"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_placed"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Placed"
                android:textColor="#6A7282"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_input_field"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_accepted"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Accepted"
                android:textColor="#6A7282"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_input_field"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_completed"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Completed"
                android:textColor="#6A7282"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_input_field"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_rejected"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Rejected"
                android:textColor="#6A7282"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_input_field"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progress_bar_admin"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginTop="80dp"
        android:indeterminateTint="#4F46E5"
        android:visibility="gone" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_empty_admin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_empty_state"
            android:contentDescription="No orders"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_empty_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No orders found"
            android:textSize="18sp"
            android:textColor="#101828"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/tv_empty_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Orders will appear here once customers start placing them."
            android:textSize="13sp"
            android:textColor="#99A1AF"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- SwipeRefreshLayout wrapping the RecyclerView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_admin"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_admin_orders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
