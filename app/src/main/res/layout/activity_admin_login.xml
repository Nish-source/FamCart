    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Back Arrow -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="Back"
            android:padding="8dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Admin Shield Icon -->
        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_admin_accent"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_admin_shield"
                android:contentDescription="Admin" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Login"
            android:textSize="26sp"
            android:textColor="#101828"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.025" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in with your admin credentials"
            android:textSize="14sp"
            android:textColor="#99A1AF"
            android:fontFamily="sans-serif"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="36dp" />

        <!-- Email Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:textSize="13sp"
            android:textColor="#364153"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <!-- Email Input -->
        <EditText
            android:id="@+id/adminEmailInput"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="admin@famcart.com"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_input_field"
            android:padding="16dp"
            android:textColor="#101828"
            android:textColorHint="#99A1AF"
            android:fontFamily="sans-serif"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Password Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="13sp"
            android:textColor="#364153"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <!-- Password Input -->
        <EditText
            android:id="@+id/adminPasswordInput"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Enter admin password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:padding="16dp"
            android:textColor="#101828"
            android:textColorHint="#99A1AF"
            android:fontFamily="sans-serif"
            android:textSize="14sp"
            android:layout_marginBottom="36dp" />

        <!-- Login Button -->
        <Button
            android:id="@+id/adminLoginButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Sign In"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:background="@drawable/bg_admin_button"
            android:layout_marginBottom="16dp" />

        <!-- Hint text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin access is restricted"
            android:textColor="#99A1AF"
            android:fontFamily="sans-serif"
            android:textSize="12sp"
            android:drawableStart="@drawable/ic_admin_shield"
            android:drawablePadding="6dp"
            android:gravity="center_vertical" />

    </LinearLayout>

</ScrollView>
