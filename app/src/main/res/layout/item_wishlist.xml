<?xml version="1.0" encoding="utf-8"?>
<!-- Wishlist item card — reuses product card style with heart toggle -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Product Image -->
        <FrameLayout
            android:id="@+id/frame_image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_image_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_product_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Product image"
                android:padding="4dp"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <!-- Product Name -->
        <TextView
            android:id="@+id/tv_product_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="#101828"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@id/btn_remove"
            app:layout_constraintStart_toEndOf="@id/frame_image"
            app:layout_constraintTop_toTopOf="@id/frame_image" />

        <!-- Product Quantity -->
        <TextView
            android:id="@+id/tv_product_quantity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:textColor="#99A1AF"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/btn_remove"
            app:layout_constraintStart_toEndOf="@id/frame_image"
            app:layout_constraintTop_toBottomOf="@id/tv_product_name" />

        <!-- Remove heart button -->
        <ImageView
            android:id="@+id/btn_remove"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Remove from wishlist"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/ic_wishlist"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#EF4444" />

        <!-- Price -->
        <TextView
            android:id="@+id/tv_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-black"
            android:textColor="#101828"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/frame_image"
            app:layout_constraintStart_toEndOf="@id/frame_image" />

        <!-- Add to Cart Button -->
        <TextView
            android:id="@+id/btn_add_to_cart"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/bg_button_green_rounded"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="Add to Cart"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/frame_image"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
