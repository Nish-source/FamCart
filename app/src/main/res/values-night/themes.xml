<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for dark mode. -->
    <style name="Theme.FamCart" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dark theme colors -->
        <item name="colorPrimary">#00C853</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#00E676</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Surface and background colors for dark mode -->
        <item name="android:windowBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorOnSurfaceVariant">#B0B0B0</item>
        <item name="colorOutline">#333333</item>

        <item name="android:statusBarColor">#121212</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
    </style>
</resources>
